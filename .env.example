# JWT Configuration
# Must match the JWT_SECRET in user-service
JWT_SECRET=your-256-bit-base64-encoded-secret-key-here

# User Service Configuration
USER_SERVICE_URL=http://localhost:8081

# Development Database (MySQL)
# These are used when spring.profiles.active=dev
DB_HOST=localhost
DB_PORT=3306
DB_NAME=appointment_service_db
DB_USERNAME=root
DB_PASSWORD=root

# Production Database (MySQL)
# These are used when spring.profiles.active=prod
DB_URL=jdbc:mysql://db-host:3306/appointment_service_db
DB_USERNAME=prod_user
DB_PASSWORD=prod_password

# Application Configuration
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8082

# Optional: Logging Level
LOGGING_LEVEL_COM_HOSPITAL=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=WARN
